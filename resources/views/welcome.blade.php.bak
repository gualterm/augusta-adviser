</html>
<!DOCTYPE html>
<html lang="pt-PT">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Augusta Adviser | Consultoria de Imagem & Estética</title>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{
font-family:'Montserrat',sans-serif;
background:#faf8f5;
color:#555;
line-height:1.7;
overflow-x:hidden;
}

img{
max-width:100%;
display:block;
}

.container{
max-width:1300px;
margin:auto;
padding:0 30px;
}

h1,h2,h3{
font-family:'Cormorant Garamond',serif;
font-weight:600;
color:#6f5f54;
}

section{
padding:90px 0;
}

.btn{
display:inline-block;
padding:15px 35px;
background:#7a6b5d;
color:#fff;
text-decoration:none;
border-radius:40px;
transition:.3s;
}

.btn:hover{
transform:translateY(-2px);
opacity:.9;
}

.hero{
min-height:100vh;
position:relative;
display:flex;
align-items:center;
overflow:hidden;
background:#f8f4f1;
}

.hero::before{
content:'';
position:absolute;
inset:0;
background:url('/images/Marta.png') center center;
background-size:cover;
opacity:.35;
}

.hero::after{
content:'';
position:absolute;
right:-250px;
top:50%;
width:850px;
height:850px;
transform:translateY(-50%);
background:url('/images/logoaugusta.png') center center no-repeat;
background-size:contain;
opacity:.06;
}

.hero-content{
position:relative;
z-index:10;
max-width:700px;
padding:80px 0;
}

.hero-logo{
width:260px;
margin-bottom:30px;
}

.hero h1{
font-size:78px;
line-height:.95;
margin-bottom:20px;
}

.hero-subtitle{
font-size:30px;
margin-bottom:10px;
color:#7d6d61;
}

.hero-tag{
font-size:18px;
letter-spacing:2px;
text-transform:uppercase;
margin-bottom:25px;
color:#9b8a7c;
}

.hero-slogan{
font-size:22px;
font-style:italic;
margin-bottom:40px;
color:#6d6157;
}

.section-title{
font-size:56px;
text-align:center;
margin-bottom:10px;
}

.divider{
width:80px;
height:2px;
background:#cbb9aa;
margin:0 auto 30px;
}

.section-intro{
max-width:900px;
margin:auto;
text-align:center;
font-size:18px;
}

.specialties{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:30px;
margin-top:50px;
}

.card{
background:#fff;
border-radius:20px;
overflow:hidden;
box-shadow:0 10px 30px rgba(0,0,0,.08);
}

.card img{
height:260px;
width:100%;
object-fit:cover;
}

.card-content{
padding:25px;
}

.card-content h3{
font-size:32px;
margin-bottom:10px;
}

.card-content p{
font-size:15px;
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
gap:25px;
}

.gallery img{
border-radius:20px;
height:350px;
width:100%;
object-fit:cover;
box-shadow:0 8px 25px rgba(0,0,0,.08);
}
.about{
display:grid;
grid-template-columns:1fr 1fr;
gap:60px;
align-items:center;
}

.about img{
width:100%;
border-radius:25px;
box-shadow:0 10px 30px rgba(0,0,0,.10);
}

.about-text h2{
font-size:52px;
margin-bottom:20px;
}

.about-text p{
margin-bottom:20px;
font-size:17px;
}

.contact-box{
background:#f2ebe6;
padding:50px;
border-radius:25px;
text-align:center;
}

.contact-box h2{
font-size:50px;
margin-bottom:20px;
}

.contact-box p{
margin-bottom:10px;
}

.instagram-section{
background:#fff;
}

.instagram-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
margin-top:40px;
}

.instagram-grid img{
height:280px;
width:100%;
object-fit:cover;
border-radius:15px;
}

.footer{
background:#efe5de;
padding:50px 0;
text-align:center;
margin-top:80px;
}

.footer-logo{
width:180px;
margin:0 auto 20px;
opacity:.35;
}

.map-container{
margin-top:40px;
border-radius:20px;
overflow:hidden;
box-shadow:0 10px 25px rgba(0,0,0,.08);
}

iframe{
width:100%;
height:450px;
border:0;
}

.fashion-gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
margin-top:40px;
}

.fashion-gallery img{
width:100%;
height:380px;
object-fit:cover;
border-radius:18px;
box-shadow:0 8px 25px rgba(0,0,0,.08);
}

@media(max-width:900px){

.hero h1{
font-size:52px;
}

.hero-subtitle{
font-size:24px;
}

.about{
grid-template-columns:1fr;
}

.section-title{
font-size:42px;
}

}

</style>
</head>

