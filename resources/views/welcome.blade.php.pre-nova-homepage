<!DOCTYPE html>
<html lang="pt-PT">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Augusta Adviser | Consultoria de Imagem & Estética</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial,Helvetica,sans-serif;
    background:#faf8f5;
    color:#555;
    line-height:1.6;
}

.container{
    max-width:1200px;
    margin:auto;
    padding:0 20px;
}

header{
    background:#f4e2d8;
    padding:60px 0;
}

.hero{
    display:flex;
    align-items:center;
    gap:50px;
}

.hero-left,
.hero-right{
    flex:1;
}

.hero-image{
    width:100%;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.15);
}

.logo{
    width:280px;
    max-width:100%;
    display:block;
    margin-bottom:25px;
}

h1{
    font-size:56px;
    color:#7a6b5d;
    margin-bottom:10px;
}

.subtitle{
    font-size:28px;
    margin-bottom:10px;
}

.slogan{
    margin-top:20px;
    font-style:italic;
}

.btn{
    display:inline-block;
    margin-top:30px;
    background:#7a6b5d;
    color:#fff;
    text-decoration:none;
    padding:14px 28px;
    border-radius:10px;
}

section{
    padding:70px 0;
}

h2{
    color:#7a6b5d;
    margin-bottom:25px;
    font-size:38px;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:white;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0 5px 20px rgba(0,0,0,.08);
}

.card img{
    width:100%;
    height:260px;
    object-fit:cover;
}

.card-content{
    padding:20px;
}

.gallery{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:25px;
}

.gallery img{
    width:100%;
    height:320px;
    object-fit:cover;
    border-radius:15px;
    box-shadow:0 5px 20px rgba(0,0,0,.08);
}

.about{
    display:flex;
    gap:40px;
    align-items:center;
}

.about img{
    width:380px;
    max-width:100%;
    border-radius:20px;
}

.about-text{
    flex:1;
}

.contact{
    background:#dfe7de;
    text-align:center;
    border-radius:20px;
    padding:50px;
}

footer{
    background:#f4e2d8;
    text-align:center;
    padding:30px;
    margin-top:50px;
}

@media(max-width:900px){

    .hero{
        flex-direction:column;
    }

    .about{
        flex-direction:column;
    }

    h1{
        font-size:40px;
    }

    .subtitle{
        font-size:22px;
    }
}

</style>
</head>

